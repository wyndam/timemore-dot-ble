.detail-content {
  flex: 1;
  padding: 20rpx;
  padding-bottom: 160rpx;
}

.detail-stats {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.detail-stat {
  background: #0d0d0d;
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
}

.detail-stat-label {
  font-size: 22rpx;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
}

.detail-stat-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #f59e0b;
  display: block;
}

.detail-stat-value.green {
  color: #4ade80;
}
