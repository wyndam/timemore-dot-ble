<view class="page-container">
  <view class="header" style="padding-top: {{statusBarHeight + 10}}px; padding-right: {{headerRight}}px;">
    <view class="header-left">
      <view class="back-btn" bindtap="goBack">‹ 返回</view>
    </view>
    <text class="header-title">{{title}}</text>
    <view class="header-actions"></view>
  </view>

  <scroll-view class="detail-content" scroll-y="true">
    <!-- 统计数据 -->
    <view class="detail-stats">
      <view class="detail-stat" wx:if="{{type !== 'espresso'}}">
        <text class="detail-stat-label">咖啡粉重</text>
        <text class="detail-stat-value green">{{coffeeWeightText}}</text>
      </view>
      <view class="detail-stat">
        <text class="detail-stat-label">出液重量</text>
        <text class="detail-stat-value">{{maxWeightText}}</text>
      </view>
      <view class="detail-stat">
        <text class="detail-stat-label">时长</text>
        <text class="detail-stat-value">{{durationText}}</text>
      </view>
      <view class="detail-stat" wx:if="{{type !== 'espresso'}}">
        <text class="detail-stat-label">平均流速</text>
        <text class="detail-stat-value">{{avgFlowText}}</text>
      </view>
    </view>

    <!-- 曲线图 -->
    <view class="chart-container" wx:if="{{hasData}}">
      <view class="chart-title">注水曲线</view>
      <canvas type="2d" id="historyChart" style="width: 100%; height: 240rpx;"></canvas>
    </view>

    <button class="btn-delete" bindtap="deleteRecord">删除此记录</button>
  </scroll-view>
</view>
