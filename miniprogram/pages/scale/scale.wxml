<view class="page-container">
  <!-- 顶部状态栏 -->
  <view class="header" style="padding-top: {{statusBarHeight + 10}}px; padding-right: {{headerRight}}px;">
    <view class="device-status">
      <view class="status-dot {{connected ? 'connected' : ''}} {{connecting ? 'connecting' : ''}}"></view>
      <text class="device-name">{{deviceName}}</text>
      <text class="state-badge">称重</text>
    </view>
    <view class="header-actions">
      <view class="icon-btn" bindtap="goHistory">📜</view>
    </view>
  </view>

  <!-- 主内容区 -->
  <view class="main scale-main">
    <view class="weight-display">
      <view class="weight-row">
        <text class="weight-value">{{weight}}</text>
        <text class="weight-unit">g</text>
      </view>
    </view>

    <button class="tare-btn-full" bindtap="onTare" disabled="{{!connected}}">去皮</button>

    <view class="mode-buttons">
      <view class="mode-btn {{connected ? '' : 'disabled'}}" bindtap="enterBrewMode">
        <image class="mode-btn-img" src="/images/brew.svg" mode="aspectFit"/>
        <text class="mode-btn-label">手冲咖啡</text>
      </view>
      <view class="mode-btn {{connected ? '' : 'disabled'}}" bindtap="enterEspressoMode">
        <image class="mode-btn-img" src="/images/espresso.svg" mode="aspectFit"/>
        <text class="mode-btn-label">意式咖啡</text>
      </view>
    </view>
  </view>

  <!-- 底部连接栏 -->
  <view class="connect-bar">
    <button class="btn-connect {{connected ? 'connected' : ''}}" bindtap="onConnect" disabled="{{connecting}}">
      {{connectBtnText}}
    </button>
  </view>
</view>
