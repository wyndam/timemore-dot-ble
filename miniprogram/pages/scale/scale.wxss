.main.scale-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 32rpx;
  padding-bottom: 160rpx;
}

.tare-btn-full {
  width: 90%;
  max-width: 720rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  border: 1rpx solid #333;
  background: #1a1a1a;
  color: #888;
  font-size: 32rpx;
  font-weight: 500;
  line-height: 1;
}

.tare-btn-full::after {
  border: none;
}

.tare-btn-full[disabled] {
  opacity: 0.4;
}

.mode-buttons {
  display: flex;
  gap: 32rpx;
  width: 90%;
  max-width: 720rpx;
}

.mode-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 12rpx;
  background: transparent;
  border-radius: 24rpx;
  color: #888;
}

.mode-btn.disabled {
  opacity: 0.35;
}

.mode-btn-icon {
  font-size: 96rpx;
  margin-bottom: 8rpx;
}

.mode-btn-img {
  width: 136rpx;
  height: 136rpx;
  margin-bottom: 8rpx;
}

.mode-btn-label {
  font-size: 24rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
}
