.recipe-page-content {
  flex: 1;
  padding: 20rpx;
  padding-bottom: 160rpx;
}

.recipe-item-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.recipe-item-left {
  flex: 1;
}

.recipe-item-btns {
  display: flex;
  gap: 16rpx;
  flex-shrink: 0;
}

.recipe-item-btn {
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  border: 1rpx solid #333;
  background: #0d0d0d;
  color: #888;
  font-size: 24rpx;
}

.recipe-item-btn.danger {
  color: #f87171;
  border-color: #f87171;
}

.recipe-item-stages {
  display: flex;
  gap: 8rpx;
  margin-top: 12rpx;
  flex-wrap: wrap;
}

.recipe-item-stage {
  background: #2a2a2a;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  color: #888;
}
