<view class="page-container">
  <view class="header" style="padding-top: {{statusBarHeight + 10}}px; padding-right: {{headerRight}}px;">
    <view class="header-left">
      <view class="back-btn" bindtap="goBack">‹ 返回</view>
    </view>
    <text class="header-title">冲煮方案</text>
    <view class="header-actions">
      <view class="icon-btn" bindtap="addRecipe">+</view>
    </view>
  </view>

  <scroll-view class="recipe-page-content" scroll-y="true">
    <view class="list-item {{item.selected ? 'selected' : ''}}" wx:for="{{recipes}}" wx:key="id" bindtap="selectRecipe" data-id="{{item.id}}">
      <view class="recipe-item-top">
        <view class="recipe-item-left">
          <text class="list-item-name">{{item.name}}</text>
          <text class="list-item-info">粉水比 {{item.ratio}} · {{item.stageCount}}段注水</text>
        </view>
        <view class="recipe-item-btns">
          <view class="recipe-item-btn" catchtap="editRecipe" data-id="{{item.id}}">编辑</view>
          <view class="recipe-item-btn danger" wx:if="{{!item.isDefault}}" catchtap="deleteRecipe" data-id="{{item.id}}">删除</view>
        </view>
      </view>
      <view class="recipe-item-stages">
        <text class="recipe-item-stage" wx:for="{{item.stageLabels}}" wx:for-item="label" wx:key="*this">{{label}}</text>
      </view>
    </view>
  </scroll-view>
</view>
