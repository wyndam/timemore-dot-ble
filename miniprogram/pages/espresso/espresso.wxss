.main.espresso-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.espresso-timer-section {
  text-align: center;
  padding: 32rpx 0;
}

.espresso-timer {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
}

.espresso-timer-value {
  font-size: 96rpx;
  font-weight: 200;
  font-family: 'Courier New', monospace;
  color: #f59e0b;
}

.espresso-timer-unit {
  font-size: 32rpx;
  color: #666;
}
